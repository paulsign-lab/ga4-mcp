{%- comment -%}
========================================================================
  Shopify dataLayer Snippet — Generated by site-marketing-infra-setup skill

  Placeholders to replace at generation time:
   · {{ SITE_BRAND_NAME }}     → "Janibell" / "Brand X"
   · {{ INDUSTRY_MAP_JSON }}   → JS object of handle → industry, from config
   · {{ MODEL_TYPE }}          → "b2b_lead" or "d2c_ecommerce"

  Install location: layout/theme.liquid <head>, AFTER the GTM snippet.

  This template auto-adapts to both B2B and D2C event matrices.
  · B2B mode: emits view_item / view_item_list / request_quote_meta /
    contact_form_* / catalog_download_*
  · D2C mode: emits view_item / view_item_list / add_to_cart / view_cart /
    begin_checkout / purchase (via order status)
========================================================================
{%- endcomment -%}

<script>
  (function () {
    window.dataLayer = window.dataLayer || [];

    var MODEL = '{{ MODEL_TYPE }}';
    var BRAND = '{{ SITE_BRAND_NAME }}';

    // ---------- Industry map (filled by skill at generation time) ----------
    var INDUSTRY_MAP = {{ INDUSTRY_MAP_JSON }};

    // Legacy / migration fallback (filled when old handles exist)
    var LEGACY_MAP = {{ LEGACY_INDUSTRY_MAP_JSON | default: '{}' }};

    function detectIndustry() {
      {%- if template contains 'collection' -%}
        var h = "{{ collection.handle | default: '' }}".toLowerCase()
                  .replace(/사본$/, '').replace(/%ec%82%ac%eb%b3%b8$/i, '');
        return INDUSTRY_MAP[h] || LEGACY_MAP[h] || 'OTHER';
      {%- elsif template contains 'product' -%}
        var handles = "{{ product.collections | map: 'handle' | join: ',' }}".toLowerCase()
                    .split(',').map(function(s){return s.replace(/사본$/,'').replace(/%ec%82%ac%eb%b3%b8$/i,'');});
        for (var i=0; i<handles.length; i++) {
          if (INDUSTRY_MAP[handles[i]]) return INDUSTRY_MAP[handles[i]];
          if (LEGACY_MAP[handles[i]])   return LEGACY_MAP[handles[i]];
        }
        return 'OTHER';
      {%- else -%}
        return 'NONE';
      {%- endif -%}
    }

    // ---------- (1) Common page-level push ----------
    window.dataLayer.push({
      'page_type':     '{{ template | default: "unknown" }}',
      'page_location': window.location.href,
      'page_path':     window.location.pathname,
      'industry':      detectIndustry(),
      'user_logged_in': {% if customer %}true{% else %}false{% endif %},
      'customer_tier': {% if customer %}'{{ customer.tags | first | default: "registered" }}'{% else %}'guest'{% endif %},
      'shop_currency': '{{ shop.currency }}',
      'shop_locale':   '{{ request.locale.iso_code }}'
    });

    {%- if template contains 'product' -%}
      // ---------- (2) PDP: view_item ----------
      window.dataLayer.push({
        'event': 'view_item',
        'product_handle': '{{ product.handle }}',
        'product_title':  {{ product.title | json }},
        'product_category':'{{ product.product_type | default: "" }}',
        'industry':       detectIndustry(),
        'ecommerce': {
          'currency': '{{ shop.currency }}',
          'items': [{
            'item_id':    '{{ product.handle }}',
            'item_name':  {{ product.title | json }},
            'item_brand': BRAND,
            'item_category': detectIndustry(),
            'price': {{ product.price | divided_by: 100.0 }}
          }]
        }
      });

      {% comment %} B2B-only: capture CTA clicks with section context {% endcomment %}
      if (MODEL === 'b2b_lead') {
        document.addEventListener('click', function (e) {
          var el = e.target.closest('a, button'); if (!el) return;
          var txt = (el.textContent || '').trim().toLowerCase();
          if (/contact\s*us|request\s*a?\s*quote|get\s*a?\s*quote/i.test(txt)) {
            var section = el.closest('[data-section-type], section, [class*="section"]');
            var sectionName = section ? (section.getAttribute('data-section-type') || section.className.split(' ')[0]) : 'pdp';
            window.dataLayer.push({
              'event': 'request_quote_meta',
              'source_section': sectionName,
              'product_handle': '{{ product.handle }}',
              'industry':       detectIndustry()
            });
          }
        });
      }

      {% comment %} D2C-only: capture Add to Cart {% endcomment %}
      if (MODEL === 'd2c_ecommerce') {
        document.addEventListener('click', function (e) {
          var el = e.target.closest('button[name=add], [data-add-to-cart], .product-form__submit'); if (!el) return;
          window.dataLayer.push({
            'event': 'add_to_cart',
            'ecommerce': {
              'currency': '{{ shop.currency }}',
              'value': {{ product.price | divided_by: 100.0 }},
              'items': [{
                'item_id':   '{{ product.handle }}',
                'item_name': {{ product.title | json }},
                'item_brand': BRAND,
                'item_category': detectIndustry(),
                'price': {{ product.price | divided_by: 100.0 }},
                'quantity': 1
              }]
            }
          });
        });
      }
    {%- endif -%}

    {%- if template contains 'collection' -%}
      // ---------- (3) PLP: view_item_list ----------
      window.dataLayer.push({
        'event': 'view_item_list',
        'industry': detectIndustry(),
        'ecommerce': {
          'item_list_name': detectIndustry(),
          'currency': '{{ shop.currency }}',
          'items': [
            {%- for p in collection.products limit: 24 -%}
              {
                'item_id': '{{ p.handle }}',
                'item_name': {{ p.title | json }},
                'item_brand': BRAND,
                'item_category': detectIndustry(),
                'index': {{ forloop.index0 }}
              }{% unless forloop.last %},{% endunless %}
            {%- endfor -%}
          ]
        }
      });
    {%- endif -%}

    {%- if template == 'cart' -%}
      // ---------- D2C: view_cart ----------
      if (MODEL === 'd2c_ecommerce') {
        window.dataLayer.push({
          'event': 'view_cart',
          'ecommerce': {
            'currency': '{{ shop.currency }}',
            'value': {{ cart.total_price | divided_by: 100.0 }},
            'items': [
              {%- for item in cart.items -%}
                {
                  'item_id': '{{ item.product.handle }}',
                  'item_name': {{ item.product.title | json }},
                  'price': {{ item.price | divided_by: 100.0 }},
                  'quantity': {{ item.quantity }}
                }{% unless forloop.last %},{% endunless %}
              {%- endfor -%}
            ]
          }
        });
      }
    {%- endif -%}

    {%- if template == 'page.contact-us' or template contains 'contact' -%}
      // ---------- (4) Contact form (B2B) ----------
      if (MODEL === 'b2b_lead') {
        document.addEventListener('DOMContentLoaded', function () {
          var form = document.querySelector('form.contact-form, form[action$="/contact"]');
          if (!form) return;
          var started = false;
          form.addEventListener('focusin', function () {
            if (started) return; started = true;
            window.dataLayer.push({
              'event':'contact_form_start',
              'form_location':'/pages/contact-us'
            });
          });
          form.addEventListener('submit', function () {
            var get = function (name) {
              var x = form.querySelector('[name="contact['+name+']"]'); return x ? x.value : '';
            };
            window.dataLayer.push({
              'event':'contact_form_submit',
              'form_location':'/pages/contact-us',
              'industry': get('industry') || detectIndustry(),
              'inquiry_type': get('inquiry_type'),
              'company': get('company'),
              'country': get('country'),
              'quantity_range': get('quantity_range')
            });
          });
        });
      }
    {%- endif -%}

    {%- if template == 'page.catalogue' or request.path contains '/catalogue' -%}
      // ---------- (5) Catalog (B2B) ----------
      if (MODEL === 'b2b_lead') {
        document.addEventListener('klaviyoForms', function (e) {
          if (e.detail && (e.detail.type === 'submit' || e.detail.type === 'submit-success')) {
            window.dataLayer.push({
              'event': 'catalog_download_start',
              'industry': detectIndustry(),
              'klaviyo_form_id': e.detail.formId
            });
          }
        });
        document.addEventListener('click', function (e) {
          var a = e.target.closest('a[data-catalog-download], a.btn-catalog-pdf, a[href*="/cdn/shop/files/"][href$=".pdf"]');
          if (!a) return;
          window.dataLayer.push({
            'event':'catalog_download_complete',
            'file_name': a.getAttribute('download') || a.href.split('/').pop(),
            'industry':  detectIndustry()
          });
        });
      }
    {%- endif -%}

    // ---------- (6) Klaviyo generic forms (both models) ----------
    document.addEventListener('klaviyoForms', function (e) {
      if (!e.detail) return;
      var isCatalog = /catalog/i.test(window.location.pathname);
      if (isCatalog) return;
      if (e.detail.type === 'submit' || e.detail.type === 'submit-success') {
        window.dataLayer.push({
          'event':'klaviyo_form_submit',
          'klaviyo_form_id': e.detail.formId,
          'source_page': window.location.pathname,
          'industry': detectIndustry()
        });
      }
    });

  })();
</script>
{%- comment -%} End site-marketing-infra-setup skill — Shopify dataLayer {%- endcomment -%}
